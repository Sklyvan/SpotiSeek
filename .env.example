# Spotify Web API credentials (Client Credentials flow).
# Create a free app at https://developer.spotify.com/dashboard to obtain these.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Soulseek account used by aioslsk to log in to the network.
SOULSEEK_USERNAME=your_soulseek_username
SOULSEEK_PASSWORD=your_soulseek_password

# Optional — lossless fallback (--fallback) proxy endpoints. Only needed if you
# use --fallback; set the ones you have a working proxy for. These third-party
# services rotate/go offline, so there are no defaults — find a live instance.
# SPOTISEEK_TIDAL_API_URL=https://your-hifi-api-instance
# SPOTISEEK_QOBUZ_API_URL=https://your-qobuz-rest-instance
# SPOTISEEK_AMAZON_API_URL=https://your-amazon-proxy
# SPOTISEEK_DEEZER_API_URL=https://your-deezer-proxy
