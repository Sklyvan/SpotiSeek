# Spotify Web API credentials (Client Credentials flow).
# Create a free app at https://developer.spotify.com/dashboard to obtain these.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Soulseek account used by aioslsk to log in to the network.
SOULSEEK_USERNAME=your_soulseek_username
SOULSEEK_PASSWORD=your_soulseek_password
